# Binaries
/dockyard
/bin/
*.exe
*.dll
*.so
*.dylib

# Test & coverage output
*.test
*.out
coverage.out
coverage.txt
coverage.html
coverage-test.log
# internal/coveragecheck/coverage.json is the committed threshold config — not
# an artifact — so it must stay tracked; the broad `coverage.*` glob is avoided.

# Go workspace
go.work
go.work.sum

# Dependency directory (vendored)
/vendor/

# Environment / secrets
.env
.env.*

# Editor / OS
.DS_Store
.idea/
.vscode/

# Private, non-repo discussion notes (monetization, etc. — never committed)
/_private/

# The inspector's embedded SPA bundle is built by `make build` from
# web/inspector/dist/ and staged into internal/inspector/dist/ so the
# `//go:embed all:dist` directive in internal/inspector/assets_embed.go picks
# it up. The directory is anchored by a tracked .gitkeep so the embed is
# always resolvable; the bundle output itself is a build artifact, never
# committed (otherwise every `make build` would dirty the working tree).
internal/inspector/dist/*
!internal/inspector/dist/.gitkeep

# VitePress docs site (Phase 29) — install + build artefacts. The site source
# is tracked under docs/site/ (.vitepress/config.ts, index.md, etc.); the
# node_modules tree and the built dist/cache are produced by `make docs` and
# never committed.
docs/site/node_modules/
docs/site/.vitepress/dist/
docs/site/.vitepress/cache/

# Playwright MCP scratch directory (locally captured screenshots are copied
# into docs/screenshots/phase-NN/ for the PR; the raw .playwright-mcp/
# directory is never committed).
/.playwright-mcp/
