{
  "name": "@dockyard/bridge",
  "version": "0.1.0",
  "description": "Dockyard Svelte bridge shell — the View side of the MCP Apps ui/ postMessage dialect.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "check": "svelte-check --tsconfig ./tsconfig.json && tsc --noEmit",
