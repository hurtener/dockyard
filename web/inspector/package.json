{
  "name": "@dockyard/inspector",
  "version": "0.1.0",
  "description": "Dockyard inspector frontend — the local test/debug surface; the host half of the ui/ bridge and the obs/v1 stream view, composing the dockyard-ui design system.",
  "license": "Apache-2.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check": "svelte-check --tsconfig ./tsconfig.json && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "gate": "npm run check && npm run coverage"
  },
  "dependencies": {
    "dockyard-bridge": "file:../bridge",
    "dockyard-ui": "file:../ui"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@testing-library/svelte": "^5.2.6",
    "@vitest/coverage-v8": "^3.0.5",
    "jsdom": "^25.0.1",
    "svelte": "^5.19.0",
    "svelte-check": "^4.1.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vitest": "^3.0.5"
  }
}
